# Azure / Entra ID – App-Registrierung im Azure Portal
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_REDIRECT_URI=https://statuspage.example.com/auth/callback

# Sicherheit – Session-Schlüssel.
# Leer lassen: Beim ersten Start wird automatisch ein 32-Byte-Hex-String
# generiert und unter data/secret_key persistiert (überlebt Neustarts).
# Eigenen Wert setzen mit:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Einbettungs-Widget API-Key (leer lassen = OIDC erforderlich für /embed)
EMBED_API_KEY=

# Datenbank
DATABASE_URL=sqlite+aiosqlite:///./data/statuspage.db

# Zu überwachende Dienste (Komma-getrennt, exakte Graph API Service-Namen)
MONITORED_SERVICES=Exchange Online,SharePoint Online,Microsoft Teams

# Abfrageintervall in Minuten
POLL_INTERVAL_MINUTES=10

# Anwendung
DEBUG=false
APP_TITLE=M365 Dienststatus

# Entwicklung: OIDC-Authentifizierung deaktivieren (NIEMALS in Produktion!)
# Alle Routen werden ohne Login zugänglich; angemeldeter User = "Dev User"
DISABLE_AUTH=false
